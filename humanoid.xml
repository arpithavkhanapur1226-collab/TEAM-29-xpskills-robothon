<mujoco model="humanoid">

  <!-- Better physics -->
  <option gravity="0 0 -9.81" timestep="0.002" iterations="50"/>

  <default>
    <!-- Add damping to stop shaking -->
    <joint damping="5" stiffness="10"/>
    <geom friction="1 0.1 0.1" density="1000"/>
  </default>

  <worldbody>
    <!-- Ground -->
    <geom type="plane" size="5 5 0.1" rgba="0.8 0.9 0.8 1"/>

    <!-- ROOT -->
    <body name="torso" pos="0 0 1.0">
      <joint name="root" type="free"/>

      <!-- Torso -->
      <geom type="capsule" size="0.12 0.3" fromto="0 0 0.3 0 0 -0.3" mass="8"/>

      <!-- HEAD -->
      <body name="head" pos="0 0 0.35">
        <joint name="neck" type="hinge" axis="0 1 0" range="-30 30" damping="3"/>
        <geom type="sphere" size="0.12" mass="2"/>
      </body>

      <!-- LEFT ARM -->
      <body name="left_upper_arm" pos="0.18 0 0.2">
        <joint name="left_shoulder_pitch" type="hinge" axis="0 1 0" range="-120 120" damping="4"/>
        <geom type="capsule" size="0.05 0.25" fromto="0 0 0 0 0 -0.35" mass="2"/>

        <body name="left_lower_arm" pos="0 0 -0.35">
          <joint name="left_elbow" type="hinge" axis="0 1 0" range="-120 0" damping="4"/>
          <geom type="capsule" size="0.04 0.25" fromto="0 0 0 0 0 -0.35" mass="1"/>

          <body name="left_hand" pos="0 0 -0.35">
            <geom type="sphere" size="0.05" mass="0.5"/>
          </body>
        </body>
      </body>

      <!-- RIGHT ARM -->
      <body name="right_upper_arm" pos="-0.18 0 0.2">
        <joint name="right_shoulder" type="hinge" axis="0 1 0" range="-120 120" damping="4"/>
        <geom type="capsule" size="0.05 0.25" fromto="0 0 0 0 0 -0.35" mass="2"/>

        <body name="right_lower_arm" pos="0 0 -0.35">
          <joint name="right_elbow" type="hinge" axis="0 1 0" range="-120 0" damping="4"/>
          <geom type="capsule" size="0.04 0.25" fromto="0 0 0 0 0 -0.35" mass="1"/>

          <body name="right_hand" pos="0 0 -0.35">
            <geom type="sphere" size="0.05" mass="0.5"/>
          </body>
        </body>
      </body>

      <!-- LEFT LEG -->
      <body name="left_thigh" pos="0.1 0 -0.3">
        <joint name="left_hip" type="hinge" axis="1 0 0" range="-40 40" damping="6"/>
        <geom type="capsule" size="0.08 0.35" fromto="0 0 0 0 0 -0.5" mass="5"/>

        <body name="left_shin" pos="0 0 -0.5">
          <joint name="left_knee" type="hinge" axis="1 0 0" range="-80 0" damping="6"/>
          <geom type="capsule" size="0.07 0.35" fromto="0 0 0 0 0 -0.5" mass="4"/>

          <body name="left_foot" pos="0 0 -0.5">
            <geom type="box" size="0.1 0.05 0.03" mass="2"/>
          </body>
        </body>
      </body>

      <!-- RIGHT LEG -->
      <body name="right_thigh" pos="-0.1 0 -0.3">
        <joint name="right_hip" type="hinge" axis="1 0 0" range="-40 40" damping="6"/>
        <geom type="capsule" size="0.08 0.35" fromto="0 0 0 0 0 -0.5" mass="5"/>

        <body name="right_shin" pos="0 0 -0.5">
          <joint name="right_knee" type="hinge" axis="1 0 0" range="-80 0" damping="6"/>
          <geom type="capsule" size="0.07 0.35" fromto="0 0 0 0 0 -0.5" mass="4"/>

          <body name="right_foot" pos="0 0 -0.5">
            <geom type="box" size="0.1 0.05 0.03" mass="2"/>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <!-- Actuators -->
  <actuator>
    <motor joint="left_hip" ctrlrange="-1 1"/>
    <motor joint="left_knee" ctrlrange="-1 1"/>
    <motor joint="right_hip" ctrlrange="-1 1"/>
    <motor joint="right_knee" ctrlrange="-1 1"/>
    <motor joint="left_shoulder_pitch" ctrlrange="-1 1"/>
    <motor joint="left_elbow" ctrlrange="-1 1"/>
    <motor joint="right_shoulder" ctrlrange="-1 1"/>
    <motor joint="right_elbow" ctrlrange="-1 1"/>
    <motor joint="neck" ctrlrange="-1 1"/>
  </actuator>

</mujoco>
